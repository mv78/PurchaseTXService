# Copy this file to .env and fill in values for your environment.
# Never commit .env to version control.

# ── docker-compose ────────────────────────────────────────────────────────────
# Only credentials are needed here; SPRING_PROFILES_ACTIVE, DB_URL and
# REDIS_HOST are set inside docker-compose.yml and resolved automatically.
DB_USERNAME=purchasetx_user
DB_PASSWORD=changeme

# Optional Redis overrides (defaults match the docker-compose service)
# REDIS_HOST=redis
# REDIS_PORT=6379
# REDIS_PASSWORD=

# ── docker run (without compose) ──────────────────────────────────────────────
# All three vars are required when running the app container directly:
#
#   docker run -p 8080:8080 \
#     -e SPRING_PROFILES_ACTIVE=prod \
#     -e DB_URL=jdbc:postgresql://host:5432/purchasetx \
#     -e DB_USERNAME=purchasetx_user \
#     -e DB_PASSWORD=changeme \
#     purchasetx:latest
